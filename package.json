{
  "name": "@senad-d/protectme",
  "version": "0.1.1",
  "type": "module",
  "description": "Pi extension that guards agent network and website access with global and project allow lists.",
  "license": "MIT",
  "author": "Senad Dizdarević <112484166+senad-d@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/senad-d/protectme.git"
  },
  "bugs": {
    "url": "https://github.com/senad-d/protectme/issues"
  },
  "homepage": "https://github.com/senad-d/protectme#readme",
  "keywords": [
    "protectme",
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "coding-agent",
    "agent-security",
    "network",
    "network-security",
    "network-access",
    "website-access",
    "egress-control",
    "access-control",
    "allowlist",
    "allow-list",
    "guardrail",
    "guardrails",
    "bash",
    "shell",
    "curl",
    "wget",
    "terminal",
    "typescript"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "docs/**/*.md",
    "src/**/*.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "pi --no-extensions -e .",
    "open:google": "node scripts/open-google.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run lint:eslint && npm run format:check && npm run check",
    "lint:eslint": "eslint . --max-warnings=0",
    "format:check": "node scripts/check-format.mjs",
    "test": "node --test test/*.test.mjs",
    "test:coverage": "node scripts/run-test-coverage.mjs",
    "check": "node --check scripts/check-format.mjs && node --check scripts/check-package-contents.mjs && node --check scripts/publish-npm.mjs && node --check scripts/run-test-coverage.mjs",
    "pack:dry-run": "npm pack --dry-run --json",
    "check:pack": "node scripts/check-package-contents.mjs",
    "validate": "npm run lint && npm run test && npm run check:pack"
  },
  "dependencies": {
    "tldts": "^7.0.19"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "image": "https://raw.githubusercontent.com/senad-d/ProtectMe/main/img/demo.gif"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typebox": "^1.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
